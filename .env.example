# NexCart Environment Configuration
# Copy this to .env and fill in the values

# Database
DATABASE_URL="file:./dev.db"

# NextAuth
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Features (Toggle features on/off)
# NEXT_PUBLIC_FEATURE_REVIEWS_ENABLED=true
# NEXT_PUBLIC_FEATURE_COUPONS_ENABLED=true

# AI Provider Configuration (Optional, used by TAF)
AI_PROVIDER=gemini
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=

